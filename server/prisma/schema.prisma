generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SALES
  MANAGER
  OPS
  FINANCE
  SUPER_ADMIN
}

enum SiteType {
  UNIPOLE
  GANTRY
  KIOSK
  HOARDING
}

enum SiteStatus {
  AVAILABLE
  TENTATIVE
  BOOKED
  MAINTENANCE
}

enum BookingType {
  REGULAR
  LOOSE
}

// Per-site line status inside an order
enum BookingStatus {
  TENTATIVE
  CONFIRMED
  LIVE
  COMPLETED
  CANCELLED
  WAITLIST
  STOPPED
}

// Order / quotation lifecycle
enum OrderStatus {
  QUOTATION
  CONFIRMED
  LIVE
  COMPLETED
  CANCELLED
}

enum TaxCategory {
  GST
  NON_GST
}

enum PhotoPhase {
  START
  MID
  END
}

// Each monitoring day needs three kinds of proof
enum PhotoKind {
  GPS
  NORMAL
  NEWSPAPER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum LedgerType {
  DEBIT
  CREDIT
}

enum PaymentMode {
  CASH
  UPI
  BANK
  CHEQUE
  CARD
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role     @default(SALES)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orders   Order[]           @relation("OrderBy")
  photos   MonitoringPhoto[] @relation("UploadedBy")
  invoices Invoice[]         @relation("GeneratedBy")
  payments Payment[]         @relation("PaymentBy")
  shifts   SiteShift[]       @relation("ShiftedBy")
  notes    Note[]            @relation("UserNotes")
}

// Operating entity — Saangari Ads (Non-GST only) vs Saangari Company (GST mandatory)
model Company {
  id            Int      @id @default(autoincrement())
  code          String   @unique          // "SAANGARI_ADS" | "SAANGARI_COMPANY"
  name          String                     // Display name
  legalName     String?                    // For invoice / quotation header
  gstin         String?
  pan           String?
  address       String?
  phone         String?
  email         String?
  gstMandatory  Boolean  @default(false)  // true → booking must be GST
  gstHidden     Boolean  @default(false)  // true → GST option hidden on booking form
  termsAndConditions String?              // T&Cs appended to quotation PDFs
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  orders   Order[]
  invoices Invoice[]
  payments Payment[]
  ledger   LedgerEntry[]
}

// Client-managed booking categories (institute, hospital, coaching, events…)
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orders Order[]
}

model Client {
  id          Int         @id @default(autoincrement())
  name        String
  phone       String      @unique
  email       String?
  company     String?
  gstNumber   String?
  taxCategory TaxCategory @default(NON_GST)
  state       String?     @default("Rajasthan")
  address     String?
  createdAt   DateTime    @default(now())

  orders   Order[]
  invoices Invoice[]
  ledger   LedgerEntry[]
  payments Payment[]
}

model Site {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  srNo         Int?
  zone         String
  city         String
  location     String
  light        String     @default("NL")
  width        Float      @default(0)
  height       Float      @default(0)
  qty          Int        @default(1)
  sqft         Float      @default(0)
  type         SiteType
  imageUrl     String?
  printingCost Float      @default(0)
  mountingCost Float      @default(0)
  monthlyRate  Float      @default(0)
  gstOnRate    Boolean    @default(true)
  latitude     Float?
  longitude    Float?
  status       SiteStatus @default(AVAILABLE)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())

  bookings    Booking[]
  shiftsFrom  SiteShift[] @relation("ShiftFrom")
  shiftsTo    SiteShift[] @relation("ShiftTo")
}

model PrintingPartner {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  ratePerSqft Float  @default(0)
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())

  orders Order[]
}

// Order = quotation / booking order header for a single client.
// Holds commercial terms shared across many site line-items.
model Order {
  id          Int         @id @default(autoincrement())
  orderNo     String      @unique
  client      Client      @relation(fields: [clientId], references: [id])
  clientId    Int
  createdBy   User        @relation("OrderBy", fields: [createdById], references: [id])
  createdById Int
  company     Company     @relation(fields: [companyId], references: [id])
  companyId   Int         @default(1)
  status      OrderStatus @default(QUOTATION)

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  bookingDate DateTime @default(now())
  description String?

  // Printing
  printingPartner   PrintingPartner? @relation(fields: [printingPartnerId], references: [id])
  printingPartnerId Int?
  noOfPrints        Int              @default(0)
  printRate         Float            @default(0)
  printingTotal     Float            @default(0)

  // Mounting (30-day mounting cycle)
  mountingCost Float @default(0)

  // Monitoring plan → drives reminders
  monitoring   Boolean @default(false)
  monitorStart Boolean @default(false)
  monitorMid   Boolean @default(false)
  monitorEnd   Boolean @default(false)

  // Tax
  taxCategory   TaxCategory @default(NON_GST)
  interState    Boolean     @default(false)
  placeOfSupply String?     @default("Rajasthan")

  // Commercials (computed + stored)
  discountPct     Float  @default(0)
  discountRemarks String?
  rentalSubtotal  Float  @default(0)
  addOnTotal      Float  @default(0)
  discountAmount  Float  @default(0)
  taxableAmount   Float  @default(0)
  cgst            Float  @default(0)
  sgst            Float  @default(0)
  igst            Float  @default(0)
  gstAmount       Float  @default(0)
  grandTotal      Float  @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Booking[]
  addOns    OrderAddOn[]
  payments  Payment[]
  reminders Reminder[]
  invoices  Invoice[]
}

model OrderAddOn {
  id      Int    @id @default(autoincrement())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int
  label   String
  amount  Float  @default(0)
}

// A single site line inside an order
model Booking {
  id        Int           @id @default(autoincrement())
  bookingNo String        @unique
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int
  site      Site          @relation(fields: [siteId], references: [id])
  siteId    Int
  type      BookingType   @default(REGULAR)
  status    BookingStatus @default(TENTATIVE)
  startDate DateTime
  endDate   DateTime
  days      Int
  dayRate   Float
  subtotal  Float

  // Free-text note that prints on the billing plan (quotation + invoice)
  displayNotes String?
  // Set when the display is stopped early
  stoppedAt  DateTime?
  stopReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos MonitoringPhoto[]
  shifts SiteShift[]
}

// Audit trail: a booking line moved from one site to another mid-campaign
model SiteShift {
  id        Int      @id @default(autoincrement())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId Int
  fromSite  Site     @relation("ShiftFrom", fields: [fromSiteId], references: [id])
  fromSiteId Int
  toSite    Site     @relation("ShiftTo", fields: [toSiteId], references: [id])
  toSiteId  Int
  reason    String?
  shiftedAt DateTime @default(now())
  by        User     @relation("ShiftedBy", fields: [byId], references: [id])
  byId      Int
}

model MonitoringPhoto {
  id           Int        @id @default(autoincrement())
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId    Int
  phase        PhotoPhase
  kind         PhotoKind  @default(NORMAL)
  filePath     String
  latitude     Float?
  longitude    Float?
  takenAt      DateTime   @default(now())
  uploadedBy   User       @relation("UploadedBy", fields: [uploadedById], references: [id])
  uploadedById Int
  remarks      String?

  // One photo per (line, phase, kind) — re-uploading replaces it
  @@unique([bookingId, phase, kind])
}

// In-app monitoring reminder for an order phase (START / MID / END)
model Reminder {
  id        Int        @id @default(autoincrement())
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int
  phase     PhotoPhase
  dueDate   DateTime
  done      Boolean    @default(false)
  createdAt DateTime   @default(now())
}

model Payment {
  id       Int         @id @default(autoincrement())
  order    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId  Int
  client   Client      @relation(fields: [clientId], references: [id])
  clientId Int
  company  Company     @relation(fields: [companyId], references: [id])
  companyId Int        @default(1)
  // Gross amount settled against the order. TDS is remitted to the government
  // on the client's behalf, so the order is credited with `amount`, while
  // `netReceived` is what actually landed in the bank.
  amount   Float
  mode     PaymentMode @default(CASH)

  tdsApplicable Boolean @default(false)
  tdsPct        Float   @default(0)
  tdsAmount     Float   @default(0)
  netReceived   Float   @default(0)

  reference    String?
  notes        String?
  receivedAt   DateTime @default(now())
  recordedBy   User     @relation("PaymentBy", fields: [recordedById], references: [id])
  recordedById Int
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNo     String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  orderId       Int
  client        Client        @relation(fields: [clientId], references: [id])
  clientId      Int
  company       Company       @relation(fields: [companyId], references: [id])
  companyId     Int           @default(1)
  taxCategory   TaxCategory
  interState    Boolean       @default(false)
  amount        Float
  gstRate       Float         @default(18)
  cgst          Float         @default(0)
  sgst          Float         @default(0)
  igst          Float         @default(0)
  gstAmount     Float         @default(0)
  total         Float
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime      @default(now())
  generatedBy   User          @relation("GeneratedBy", fields: [generatedById], references: [id])
  generatedById Int

  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id        Int        @id @default(autoincrement())
  client    Client     @relation(fields: [clientId], references: [id])
  clientId  Int
  company   Company    @relation(fields: [companyId], references: [id])
  companyId Int        @default(1)
  invoice   Invoice?   @relation(fields: [invoiceId], references: [id])
  invoiceId Int?
  type      LedgerType
  amount    Float
  narration String
  date      DateTime   @default(now())
}

model Counter {
  key   String @id
  value Int    @default(0)
}

model Note {
  id        Int      @id @default(autoincrement())
  content   String
  isDone    Boolean  @default(false)
  user      User     @relation("UserNotes", fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
